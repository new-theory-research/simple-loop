target/

# simple-loop ephemeral state (per loop's own conventions)
.loop/logs/
.loop/worktrees/
.loop/state/daemon.pid
.loop/state/signals/
.loop/state/pending-dispatch.json
.loop/state/pending-merge.json
.loop/state/heartbeat.json
.loop/state/log.jsonl
.loop/state/metrics.jsonl
.loop/config.local.sh
# harness-001/003: running.json is daemon-local volatile state — never committed.
# Each daemon projects its own local copy from cards + runtime-events.jsonl.
# Two daemons cannot clobber each other's running.json via a shared git main.
.loop/state/running.json

# Zensical build output
site/
.site/
.loop/state/last-queen-error.json
.loop/state/last-queen-success.json
# issue #15: repeat-failure fingerprint counter — daemon-local volatile state.
.loop/state/failure-fingerprints.json
__pycache__/
.loop/state/progress.json
.loop/state/runtime-events.jsonl
.claude/
