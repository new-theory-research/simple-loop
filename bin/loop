#!/bin/bash
# Simple Loop — autonomous agent loop CLI
#
# Usage: loop <command> [args]
# See 'loop help' for available commands.

set -uo pipefail

# ── Path Resolution ──────────────────────────────────────────

# Find .loop/ directory by walking up from cwd
find_loop_dir() {
    local dir="$PWD"
    while [ "$dir" != "/" ]; do
        if [ -d "$dir/.loop" ]; then
            echo "$dir/.loop"
            return 0
        fi
        dir="$(dirname "$dir")"
    done
    return 1
}

# Simple Loop install location
SIMPLE_LOOP_HOME="${SIMPLE_LOOP_HOME:-$HOME/.local/share/simple-loop}"
LIB_DIR="$SIMPLE_LOOP_HOME/lib"
TEMPLATES_DIR="$SIMPLE_LOOP_HOME/templates"
CORE_DIR="$SIMPLE_LOOP_HOME/core"
MODULES_DIR="$SIMPLE_LOOP_HOME/modules"

# Resolve source dir (for running from repo without install)
resolve_source_dir() {
    local script_dir
    script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
    echo "$script_dir"
}

# Find module dir — checks installed location, then source repo
find_module_dir() {
    local module_name="$1"
    if [ -d "$MODULES_DIR/$module_name" ]; then
        echo "$MODULES_DIR/$module_name"
    else
        local source_dir
        source_dir="$(resolve_source_dir)"
        if [ -d "$source_dir/modules/$module_name" ]; then
            echo "$source_dir/modules/$module_name"
        else
            return 1
        fi
    fi
}

# Find core dir — checks installed location, then source repo
find_core_dir() {
    if [ -d "$CORE_DIR" ]; then
        echo "$CORE_DIR"
    else
        local source_dir
        source_dir="$(resolve_source_dir)"
        if [ -d "$source_dir/core" ]; then
            echo "$source_dir/core"
        else
            return 1
        fi
    fi
}

# ── Helpers ──────────────────────────────────────────────────

die() { echo "Error: $1" >&2; exit 1; }

require_loop_dir() {
    LOOP_DIR=$(find_loop_dir) || die "No .loop/ found. Run 'loop init' first."
    PROJECT_DIR="$(dirname "$LOOP_DIR")"
    STATE_DIR="$LOOP_DIR/state"
    SIGNALS_DIR="$STATE_DIR/signals"
    LOG_DIR="$LOOP_DIR/logs"
    LOG_FILE="$LOG_DIR/daemon.log"
    PID_FILE="$STATE_DIR/daemon.pid"

    # Source project config
    [ -f "$LOOP_DIR/config.sh" ] && source "$LOOP_DIR/config.sh"
}

pid_alive() {
    [ -f "$PID_FILE" ] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null
}

# Merge simple_loop provenance from PROVENANCE.json into a config.json
_seed_simple_loop_config() {
    local config_file="$1"
    local provenance_file="$SIMPLE_LOOP_HOME/PROVENANCE.json"
    python3 - "$config_file" "$provenance_file" <<'PYEOF'
import json, sys, os, datetime
config_file, provenance_file = sys.argv[1], sys.argv[2]
try:
    with open(config_file) as f:
        config = json.load(f)
except Exception:
    sys.exit(0)
sl = {
    'commit': 'unknown',
    'installed_at': datetime.datetime.utcnow().strftime('%Y-%m-%dT%H:%M:%SZ'),
    'source_repo': 'unknown'
}
if os.path.exists(provenance_file):
    try:
        with open(provenance_file) as pf:
            prov = json.load(pf)
        sl['commit'] = prov.get('source_commit', 'unknown')
        sl['installed_at'] = prov.get('installed_at', sl['installed_at'])
        sl['source_repo'] = prov.get('source_repo', 'unknown')
    except Exception:
        pass
config['simple_loop'] = sl
with open(config_file, 'w') as f:
    json.dump(config, f, indent=2)
    f.write('\n')
PYEOF
}

# ── init ─────────────────────────────────────────────────────

cmd_init() {
    # Flag parsing
    local _init_mode="interactive"
    local _dry_run=false

    for _arg in "$@"; do
        case "$_arg" in
            --minimal)   _init_mode="minimal" ;;
            --wiki-full) _init_mode="wiki-full" ;;
            --dry-run)   _dry_run=true ;;
            *) die "Unknown flag: $_arg" ;;
        esac
    done

    if [ -d ".loop" ]; then
        die "Simple-loop already initialized here. Use 'loop init --force' to overwrite."
    fi

    # ── Non-interactive modes (--minimal, --wiki-full) ────────
    if [ "$_init_mode" = "minimal" ] || [ "$_init_mode" = "wiki-full" ]; then
        local _project_name
        _project_name="$(basename "$PWD")"

        if [ "$_dry_run" = true ]; then
            echo "Would create (dry-run — no files written):"
            echo "  .loop/state/running.json"
            echo "  .loop/state/goals.md"
            echo "  .loop/state/stewardship-log.md"
            echo "  .loop/signals/"
            echo "  .loop/config.json"
            echo "  .loop/prompts/queen.md"
            echo "  .loop/prompts/worker.md"
            if [ "$_init_mode" = "wiki-full" ]; then
                echo "  wiki/soul.md"
                echo "  wiki/CLAUDE.md"
                echo "  wiki/briefs/cards/README.md"
                echo "  wiki/briefs/runway.md"
                echo "  wiki/briefs/_template.md"
                echo "  wiki/operating-docs/README.md"
                echo "  wiki/operating-docs/director-context.md"
                echo "  wiki/decisions/README.md"
                echo "  wiki/riffs/README.md"
                echo "  zensical.toml"
            fi
            return 0
        fi

        mkdir -p .loop/state .loop/signals .loop/prompts

        # Scaffold the daemon's queen + worker prompts so the first tick can find
        # them at .loop/prompts/{queen,worker}.md (the path daemon.sh expects).
        # Idempotent — never clobber a prompt the user already customized.
        local _sl_root
        _sl_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
        if [ ! -f ".loop/prompts/queen.md" ] && [ -f "$_sl_root/templates/prompts/queen.md" ]; then
            cp "$_sl_root/templates/prompts/queen.md" .loop/prompts/queen.md
        fi
        if [ ! -f ".loop/prompts/worker.md" ] && [ -f "$_sl_root/templates/prompts/worker.md" ]; then
            cp "$_sl_root/templates/prompts/worker.md" .loop/prompts/worker.md
        fi

        cat > .loop/state/running.json <<'JSON'
{"active": [], "completed_pending_eval": [], "pending_merges": [], "awaiting_review": []}
JSON

        cat > .loop/state/goals.md <<'MD'
# Goals

## Awaiting Mattie (not queued)

## Credential-gated — NOT dispatchable

## Queued next
MD

        cat > .loop/state/stewardship-log.md <<'MD'
# Stewardship Log
MD

        cat > .loop/config.json <<CJSON
{
  "project_name": "$_project_name",
  "version": "0.2.0",
  "heartbeat_interval": 300,
  "worker_cooldown": 30,
  "max_iterations": 20,
  "git": {
    "remote": "origin",
    "main_branch": "main"
  },
  "modules": [],
  "beehive": {}
}
CJSON
        _seed_simple_loop_config ".loop/config.json"

        # ── Wiki-full scaffold ────────────────────────────────────
        if [ "$_init_mode" = "wiki-full" ]; then
            mkdir -p wiki/briefs/cards wiki/operating-docs wiki/decisions wiki/riffs

            if [ -f "$_sl_root/docs/templates/soul-template.md" ]; then
                cp "$_sl_root/docs/templates/soul-template.md" wiki/soul.md
            else
                cat > wiki/soul.md <<'MD'
# Soul

A living document. What is this project, why does it exist, what does it refuse to become?

## What this project is

<!-- Write it here. -->

## Why it exists

<!-- What breaks if this project doesn't exist? -->

## What it refuses to be

<!-- The constraints that make this project coherent. Write the refusals. -->

## Current questions

<!-- What's unsettled. The things you'd answer differently in three months. -->
MD
            fi

            if [ -f "$_sl_root/docs/templates/CLAUDE-md-template.md" ]; then
                cp "$_sl_root/docs/templates/CLAUDE-md-template.md" wiki/CLAUDE.md
            else
                cat > wiki/CLAUDE.md <<'MD'
# Agent instructions

## Session-start load order

Always, in order:

1. **Memories auto-load** — feedback_*.md + project_*.md + reference_*.md. Review the index.
2. **`CLAUDE.md`** — auto-loaded. Conventions, tech stack, who-operates-here.
3. **`wiki/soul.md`** — what this project refuses to be. 2 minutes.
4. **`.loop/state/goals.md`** — current priority + queue + done.
5. **`git log --oneline -30`** — recent decisions + who made them.
6. **`cat .loop/state/running.json`** — what's in flight.
7. **`ls .loop/state/signals/`** — any open escalates.
8. **`wiki/briefs/runway.md`** — upcoming pre-filed briefs. Skim the list.
9. **`wiki/operating-docs/director-context.md`** — pull-on-demand index + operating mode.

**Then** wait for direction. Do not preload briefs or research docs ahead of need.

## Three durable conventions

**Cite specifics.** `brief-NNN`, commit SHAs, `ADR-NNN` — not "recent work" or "the API thing." Specificity surfaces disagreement fast.

**Use the tools that exist.** Cards, stewardship-log, audit/capture patterns, harness-updates runbook, the memory system, runway doc. When something new comes up, first ask: does an existing tool handle this?

**Match the phase.** Clay-wetting (exploration, questions) → add to the pile, don't polish. Ship mode (commits, merges, demos) → cut and ship. Demo-prep → honest framing over perfect. Reading the phase is half the game.

## Dispatch floor

Orchestrate; don't implement. If a task will touch more than one file or produce more than 40 lines of prose/code, write a brief and dispatch. Main-thread time goes to drafting the ask, reviewing the diff, deciding — not to writing the artifact.

Context compaction is the receipt that the dispatch floor was ignored. When a session compacts, the first post-mortem question is: which of those tasks should have been subagents?

## Conventions

- **Commit prefixes:** `[scav]`, `[scaviefae]`, or `[titania]`.
- **Preserve en-dashes (–)** in writing. Don't silently convert to em-dashes.
- **Riffs** use `<!-- riff id="..." status="draft|developing|tested" could_become="..." -->` blocks. Don't clean them up.
- **Source citations** use `[source: url]` inline.
- **No LLM-speak.** No "Great question." No "Absolutely." No "I'd be happy to help." Just answer.

## Project-specific

<!-- Fill in below: who operates here, tech stack, what not to do. -->
MD
            fi

            cat > wiki/briefs/cards/README.md <<'MD'
# Brief cards

Each brief lives in its own directory here: `cards/brief-NNN-slug/`. The card collects all artifacts for one brief:

- `index.md` — the brief itself (Status: frontmatter is the source of truth for brief state)
- `plan.md` — implementation plan (optional, written by worker)
- `closeout.md` — summary written at completion
- `evaluation.md` — validator review

## Adding a brief

1. Create a directory: `mkdir wiki/briefs/cards/brief-NNN-slug/`
2. Write the brief: `wiki/briefs/cards/brief-NNN-slug/index.md` with `Status: queued` in frontmatter
3. Add it to `goals.md` under `## Queued next` (for priority ordering).
MD

            cat > wiki/briefs/runway.md <<'MD'
# Briefs runway

Pre-filed scope notes for upcoming briefs. Not dispatchable as-is — each entry is enough context for a future session to write a full brief card without rediscovering the thread. Promote to a proper `wiki/briefs/cards/brief-NNN-*/index.md` when ready to dispatch.

Queue semantics: **Queued** in `goals.md` means daemon-dispatchable. **Runway** entries here are drafts — reserved but not ready.

---

<!-- Add runway entries here as: ## Title (runway-NNN) with brief intent + context -->
MD

            # Use the bundle's brief template if available, else write a minimal one
            if [ -f "$_sl_root/templates/brief-template.md" ]; then
                cp "$_sl_root/templates/brief-template.md" wiki/briefs/_template.md
            else
                cat > wiki/briefs/_template.md <<'MD'
# Brief: [name]

**ID:** brief-NNN-slug
**Branch:** brief-NNN-slug
**Status:** queued
**Model:** sonnet

## Intent

One sentence. The artifact that exists when this brief is done.

## Motivation

Two or three sentences. Why this, why now, what breaks if we skip it.

## Scope

### In

- Specific thing this brief covers

### Out

- Specific thing this brief does NOT touch

## Tasks

1. [task]
2. [task]

## Completion criteria

- [ ] Criterion one
- [ ] Criterion two

## Escalation triggers

- Build fails three cycles in a row
- Dependency needed that isn't in the workspace

## Budget

Max N cycles. After that, stop and report.

## Anti-patterns

- Don't refactor beyond what the cycle requires
- Don't touch [specific file / area]

## Artifact

What lands when this brief closes? Where does it live?

## Verification

```bash
# commands to confirm completion criteria pass
```
MD
            fi

            cat > wiki/operating-docs/README.md <<'MD'
# Operating docs

Runbooks, procedures, and working conventions for this project. The bundle-authoritative versions of the core operating docs live at `docs/operating/` in simple-loop master. Project-specific operating docs — anything about how this project specifically runs — live here.

## Bundle docs (reference upstream for latest)

- [Harness updates](harness-updates.md) — escape hatches, propagation paths, restart protocols
- [Overnight stewardship](overnight-stewardship.md) — rubric for unattended operation
- [Hand-merge brief](hand-merge-brief.md) — recipe for manual merges when the daemon can't
- [Daemon push auth](daemon-push-auth.md) — fixing auth failures on daemon push
- [Post-session briefs](post-session-briefs.md) — audit + capture brief patterns
- [Multi-instance loop](multi-instance-loop.md) — running simple-loop across multiple projects

## Project-specific docs

<!-- Add project-specific operating docs below as they accrue. -->
MD

            if [ -f "$_sl_root/docs/templates/director-context-template.md" ]; then
                cp "$_sl_root/docs/templates/director-context-template.md" wiki/operating-docs/director-context.md
            else
                cat > wiki/operating-docs/director-context.md <<'MD'
# Director context

The onboarding package for a fresh session stepping into the director seat. Read this after the session-start load order in `CLAUDE.md`.

## Why this file exists

A fresh session without project context struggles — not from intelligence gap, from discovery gap. This doc closes the gap.

**What transfers across sessions vs what doesn't.**

| Durable (survives session end) | Dies with the session's context |
|---|---|
| Feedback memories (auto-load) | Narrative thread of the day |
| Any file on disk | Mental map of where everything lives |
| Commit history + running.json state | Voice-phase calibration |
| Goals queue + runway | Knowledge of what you *didn't* pull |
| Explicit conventions in CLAUDE.md | Nuance in pushback style |

Memories + this doc + the artifacts on disk together get you ~80% back. The remaining 20% only comes from reading widely and asking cleanly when you don't know.

## Calibrate on state — first thing, every session

```bash
git log --oneline -20
cat .loop/state/goals.md | head -60
cat .loop/state/running.json | python3 -m json.tool | head -40
```

Three minutes. Shows what landed, what's focused on, what the daemon thinks.

## Pull-on-demand index

When the conversation touches a surface, pull the specific file(s). Not before.

| If working on … | Pull |
|---|---|
| Brief writing | latest brief card as a shape reference, `wiki/briefs/runway.md` |
| Design decisions | `wiki/decisions/` — skim index, pull specific ones by number |
| Exploratory thinking | `wiki/riffs/` |
| Harness / daemon | `wiki/operating-docs/harness-updates.md` |
| Stewardship / overnight | `.loop/state/stewardship-log.md` |

<!-- Add project-specific pull-on-demand rows here. -->

## Operating mode

- **Cite specifics.** Brief IDs, commit SHAs, ADR numbers — not "recent work."
- **Pull before you commit to a position.** Don't theorize about code; read it.
- **Use the tools we've built.** Cards, stewardship-log, audit/capture patterns, runway doc. Don't invent parallel systems.
- **Match the phase.** Clay-wetting → add to the pile. Ship mode → cut and ship.
- **Dispatch reflex.** >40 lines of code/prose → write a brief. Main thread is for orchestrating, not implementing.
- **Honor taste gates.** Aesthetic judgments belong to the human. Proxy-approve only when explicitly delegated with a rubric.
- **Be honest about stubs.** "This is faked" lands better than ambiguity.
- **Push back with alternatives, not objections.** Offer the path, not just the no.
MD
            fi

            cat > wiki/decisions/README.md <<'MD'
# Decisions

ADR-style records written when a riff graduates into a committed direction, or when a contested technical choice is resolved. Each entry includes:

- **Context** — what's the situation
- **Decision** — what we chose
- **Consequences** — what this closes off or enables
- **Alternatives considered** — the paths not taken and why

Dated. Not modified after recording — if the decision reverses later, a new ADR supersedes it.

## Format

File name: `NNN-short-slug.md`. Number sequentially from 001.

## Current decisions

<!-- List decisions here as: - [NNN: title](NNN-slug.md) — one-line summary -->
MD

            cat > wiki/riffs/README.md <<'MD'
# Riffs

Exploratory thinking. Half-ideas. Things that might be wrong. Each riff carries a status tag:

- **`draft`** — first pass, not yet stress-tested
- **`developing`** — multiple revisions, gaining conviction
- **`tested`** — validated against reality; usually a step away from becoming a spec or decision

Riffs don't commit anyone. They're allowed to be wrong. When one graduates — or gets discarded — the reasoning goes into `wiki/decisions/`.

## Riff block grammar

```markdown
<!-- riff id="unique-id" status="draft|developing|tested" could_become="tweet, blog, talk, ADR, spec" -->
Exploratory thinking here. Speculative, might be wrong.
<!-- /riff -->
```

Don't clean up riff blocks. They're working state, not polish.

## Current riffs

<!-- List active riffs here as: - [title](filename.md) — `status`. One-line note. -->
MD

            cat > zensical.toml <<'TOML'
[site]
name = "Project Wiki"
description = ""

[build]
docs_dir = "wiki"
site_dir = "site"

[theme]
name = "material"

[[nav]]
title = "Home"
file = "index.md"

[[nav]]
title = "Soul"
file = "soul.md"

[[nav]]
title = "Briefs"
file = "briefs/index.md"

[[nav]]
title = "Decisions"
file = "decisions/README.md"

[[nav]]
title = "Riffs"
file = "riffs/README.md"

[[nav]]
title = "Operating Docs"
file = "operating-docs/README.md"
TOML

            echo "  wiki/ skeleton created."
        fi

        echo ""
        echo "Simple-loop scaffolded in \`$PWD\`. Next: create your first brief in \`wiki/briefs/cards/\` (or wherever your cards live)."
        echo ""
        return 0
    fi

    # ── Interactive mode (default, no flags) ──────────────────

    # Brief-014 fix 3: require gh CLI + `gh auth setup-git` before the daemon
    # ever starts. Daemon pushes survive macOS keychain locks only when gh is
    # the credential helper. Silent auth failures were the root cause of the
    # brief-013 merge sitting unpushed for ~14h on 2026-04-22.
    if ! command -v gh >/dev/null 2>&1; then
        cat >&2 <<'GHMSG'
Error: GitHub CLI (gh) is required but not installed.

Simple Loop uses `gh auth setup-git` as its git credential helper so the
daemon can push without losing auth when the machine sleeps.

Install:  https://cli.github.com/
Then:     gh auth login
          gh auth setup-git
          loop init
GHMSG
        exit 1
    fi

    if ! gh auth status >/dev/null 2>&1; then
        cat >&2 <<'GHMSG'
Error: gh CLI is installed but not authenticated.

Run:
  gh auth login
  gh auth setup-git

Then re-run `loop init`.

Why: daemon pushes run outside your terminal session. macOS keychain
unlock does not propagate. gh's stored token survives sleep + keychain
lock. Without it, merge commits sit unpushed until you intervene.
GHMSG
        exit 1
    fi

    # Soft warning on excess token scopes — not fatal. `workflow` and
    # `admin:*` are not needed for daemon operation. User can shrink with:
    #   gh auth refresh --hostname github.com --remove-scopes workflow
    local gh_scopes
    gh_scopes=$(gh auth status 2>&1 | grep -o 'Token scopes:.*' || echo "")
    if echo "$gh_scopes" | grep -qE '\bworkflow\b|\badmin:'; then
        echo "  Warning: gh token has extra scopes (workflow / admin:*) not needed by the daemon."
        echo "           Shrink with:  gh auth refresh --hostname github.com --remove-scopes workflow"
        echo ""
    fi

    echo ""
    echo "╔══════════════════════════════════════╗"
    echo "║       Simple Loop — Setup            ║"
    echo "╚══════════════════════════════════════╝"
    echo ""

    # Detect project context
    local is_git=false
    local main_branch="main"
    local detected_framework=""

    if git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
        is_git=true
        # Detect main branch
        if git show-ref --verify --quiet refs/heads/main 2>/dev/null; then
            main_branch="main"
        elif git show-ref --verify --quiet refs/heads/master 2>/dev/null; then
            main_branch="master"
        fi
    fi

    # Detect framework
    if [ -f "package.json" ]; then
        detected_framework="Node.js"
    elif [ -f "Cargo.toml" ]; then
        detected_framework="Rust"
    elif [ -f "go.mod" ]; then
        detected_framework="Go"
    elif [ -f "pyproject.toml" ] || [ -f "setup.py" ]; then
        detected_framework="Python"
    elif [ -f "*.csproj" ] 2>/dev/null || [ -f "*.sln" ] 2>/dev/null; then
        detected_framework=".NET"
    fi

    if [ -n "$detected_framework" ]; then
        echo "  Detected: $detected_framework project"
    fi
    if [ "$is_git" = true ]; then
        echo "  Git repo: yes (main branch: $main_branch)"
    fi
    echo ""

    # Ask questions
    local project_name
    local verify_cmd
    local ntfy_topic
    local confirm_branch

    read -p "  What's your project called? " project_name
    project_name="${project_name:-$(basename "$PWD")}"

    echo ""
    read -p "  What command verifies your project builds/passes? (e.g. npm test, cargo build)
  > " verify_cmd

    echo ""
    read -p "  Want push notifications? Enter an ntfy.sh topic, or press Enter to skip.
  > " ntfy_topic

    if [ "$is_git" = true ]; then
        echo ""
        read -p "  Main branch? [$main_branch] " confirm_branch
        main_branch="${confirm_branch:-$main_branch}"
    fi

    echo ""
    echo "  Creating .loop/..."

    # Scaffold directories
    mkdir -p .loop/{prompts,state/signals,evaluations,knowledge,logs,modules}

    # Write config
    cat > .loop/config.sh <<CONF
# .loop/config.sh — project configuration
PROJECT_NAME="$project_name"
HEARTBEAT_INTERVAL=300        # Idle interval (seconds)
WORKER_COOLDOWN=30            # Between worker iterations
MAX_ITERATIONS=20             # Safety limit per brief
NTFY_TOPIC="$ntfy_topic"     # ntfy.sh topic (empty = no push notifications)
VERIFY_CMD="$verify_cmd"     # Command to run after each task
GIT_REMOTE="origin"
GIT_MAIN_BRANCH="$main_branch"
CONF

    # Copy daemon prompts and brief template.
    # Generic agents (coder, reviewer, research) are workstation-installed via
    # `bash install.sh` to ~/.claude/agents/loop-*.md and addressable as
    # subagent_type values. Per-project overrides go in <project>/.claude/agents/.
    if [ -d "$TEMPLATES_DIR" ]; then
        # From installed location
        cp "$TEMPLATES_DIR/prompts/worker.md" .loop/prompts/worker.md
        cp "$TEMPLATES_DIR/prompts/queen.md" .loop/prompts/queen.md
    else
        # Running from source — look relative to this script
        local script_dir
        script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
        if [ -d "$script_dir/templates" ]; then
            cp "$script_dir/templates/prompts/worker.md" .loop/prompts/worker.md
            cp "$script_dir/templates/prompts/queen.md" .loop/prompts/queen.md
        else
            echo "  Warning: template directory not found. Creating minimal templates."
            echo "# Worker Prompt — edit this" > .loop/prompts/worker.md
            echo "# Queen Prompt — edit this" > .loop/prompts/queen.md
        fi
    fi

    # Sed project name into templates
    if command -v sed >/dev/null 2>&1; then
        find .loop/prompts .loop/agents -name '*.md' -exec \
            sed -i '' "s/{{PROJECT_NAME}}/$project_name/g" {} + 2>/dev/null || true
    fi

    # Initialize state files
    cat > .loop/state/running.json <<'JSON'
{
  "active": [],
  "completed_pending_eval": [],
  "pending_merges": [],
  "awaiting_review": []
}
JSON

    cat > .loop/state/goals.md <<'MD'
# Goals

What are you building? The conductor reads this to decide what to work on.

## Current Priority

<!-- Write your goals here. Be specific about what "done" looks like. -->
MD

    echo '{}' > .loop/state/metrics.jsonl 2>/dev/null; truncate -s 0 .loop/state/metrics.jsonl 2>/dev/null || true
    : > .loop/state/metrics.jsonl
    : > .loop/state/log.jsonl

    cat > .loop/knowledge/learnings.md <<'MD'
# Project Learnings

Agent-writable knowledge base. Add findings, patterns, and gotchas here.
MD

    # Create v2 config.json alongside v1 config.sh
    cat > .loop/config.json <<CJSON
{
  "project_name": "$project_name",
  "version": "0.2.0",
  "heartbeat_interval": 300,
  "worker_cooldown": 30,
  "max_iterations": 20,
  "verify_cmd": "$verify_cmd",
  "ntfy_topic": "$ntfy_topic",
  "git": {
    "remote": "origin",
    "main_branch": "$main_branch"
  },
  "modules": []
}
CJSON
    _seed_simple_loop_config ".loop/config.json"

    # Create persistent documents
    local core_src
    core_src=$(find_core_dir 2>/dev/null) || true

    for doc in SPEC.md HANDOFF.md RUNNING.md TROUBLESHOOTING.md; do
        if [ ! -f "$doc" ]; then
            if [ -n "$core_src" ] && [ -f "$core_src/templates/$doc" ]; then
                sed "s/{{PROJECT_NAME}}/$project_name/g" "$core_src/templates/$doc" > "$doc"
            else
                echo "# ${doc%.md}" > "$doc"
            fi
        fi
    done

    # Add logs and worktrees to gitignore
    # Brief-014: heartbeat.json is machine-local ephemeral — never commit.
    if [ -f ".gitignore" ]; then
        if ! grep -q '\.loop/logs' .gitignore 2>/dev/null; then
            echo "" >> .gitignore
            echo "# Simple Loop" >> .gitignore
            echo ".loop/logs/" >> .gitignore
            echo ".loop/worktrees/" >> .gitignore
            echo ".loop/state/heartbeat.json" >> .gitignore
        else
            grep -q '\.loop/worktrees' .gitignore || echo ".loop/worktrees/" >> .gitignore
            grep -q '\.loop/state/heartbeat.json' .gitignore || echo ".loop/state/heartbeat.json" >> .gitignore
        fi
    elif [ "$is_git" = true ]; then
        printf ".loop/logs/\n.loop/worktrees/\n.loop/state/heartbeat.json\n" > .gitignore
    fi

    # Check Agent Teams
    if command -v claude >/dev/null 2>&1; then
        local teams_enabled
        teams_enabled=$(claude config get enableAgentTeams 2>/dev/null || echo "")
        if [ "$teams_enabled" != "true" ]; then
            echo ""
            echo "  ⚠  Recommendation: enable Agent Teams for best results"
            echo "     claude config set enableAgentTeams true"
        fi
    fi

    echo ""
    echo "  ✓ .loop/ created"
    echo "  ✓ SPEC.md, HANDOFF.md, RUNNING.md, TROUBLESHOOTING.md created"
    echo ""
    echo "  Next steps:"
    echo "    1. Edit SPEC.md — what is this project and what are you building?"
    echo "    2. Add a module:  loop add research   or   loop add build"
    echo "    3. Write a brief: loop brief \"your first task\""
    echo "    4. Start the loop: loop start"
    echo ""
}

# ── brief ────────────────────────────────────────────────────

cmd_brief() {
    require_loop_dir
    local title="${1:-}"
    local no_interactive=false

    # Parse flags
    while [ $# -gt 0 ]; do
        case "$1" in
            --no-interactive) no_interactive=true; shift ;;
            *) title="$1"; shift ;;
        esac
    done

    [ -z "$title" ] && die "Usage: loop brief \"title\" [--no-interactive]"

    # Generate brief number
    local count
    count=$(find "$LOOP_DIR/briefs" -name 'brief-*.md' 2>/dev/null | wc -l | tr -d ' ')
    local num=$(printf "%03d" $((count + 1)))
    local slug
    slug=$(echo "$title" | tr '[:upper:]' '[:lower:]' | tr ' ' '-' | tr -cd 'a-z0-9-' | head -c 40)
    local brief_file="$LOOP_DIR/briefs/brief-${num}-${slug}.md"

    if [ "$no_interactive" = true ]; then
        # Just create from template
        local template="$LOOP_DIR/briefs/.template.md"
        if [ -f "$template" ]; then
            sed "s/\[title\]/$title/g; s/NNN/$num/g; s/slug/$slug/g" "$template" > "$brief_file"
        else
            cat > "$brief_file" <<BRIEF
# Brief: $title

**Branch:** brief-${num}-${slug}
**Model:** sonnet

## Goal
[What you're trying to accomplish. 1-2 sentences.]

## Tasks
1. [One iteration of work]
2. [One iteration of work]
3. [One iteration of work]

## Completion Criteria
- [ ] Criterion 1
- [ ] Criterion 2

## Verification
- Builds clean
BRIEF
        fi

        echo "Created: $brief_file"
        echo "Edit this file, then queue it with: loop start"

        # Open in editor if available
        if [ -n "${EDITOR:-}" ]; then
            "$EDITOR" "$brief_file"
        fi
    else
        # Interactive spec agent session
        echo "Starting spec session for: $title"
        echo ""

        local spec_agent="$LOOP_DIR/agents/spec.md"
        if [ ! -f "$spec_agent" ]; then
            die "Spec agent not found at $spec_agent. Run 'loop init' first."
        fi

        # Run Claude with spec agent
        cd "$PROJECT_DIR"
        claude --agent-file "$spec_agent" \
            -p "Help me write a brief for: \"$title\"

The brief should be saved to: $brief_file
Brief number: $num
Branch name: brief-${num}-${slug}

Read .loop/state/goals.md for project context.
Read .loop/knowledge/learnings.md for accumulated knowledge.
Follow the brief format in wiki/briefs/_template.md if it exists."

        if [ -f "$brief_file" ]; then
            echo ""
            echo "Brief created: $brief_file"
        else
            echo ""
            echo "No brief file was created. You can create one manually:"
            echo "  loop brief \"$title\" --no-interactive"
        fi
    fi
}

# ── start ────────────────────────────────────────────────────

cmd_start() {
    require_loop_dir
    local interval="${1:-${HEARTBEAT_INTERVAL:-300}}"

    if pid_alive; then
        die "Daemon already running (PID $(cat "$PID_FILE")). Use 'loop stop' first."
    fi

    mkdir -p "$LOG_DIR" "$SIGNALS_DIR"

    # LaunchAgent path — if the plist is installed, let launchd own the process
    local project_name
    project_name="$(basename "$PROJECT_DIR")"
    local _la_label="com.scaviefae.simpleloop.${project_name}"
    local _la_plist="$HOME/Library/LaunchAgents/${_la_label}.plist"

    if [ -f "$_la_plist" ]; then
        echo "Starting via LaunchAgent (launchd-managed)..."
        launchctl load -w "$_la_plist"
        sleep 2
        if launchctl list "$_la_label" >/dev/null 2>&1; then
            echo "Daemon running via launchd. Logs: loop logs -f"
            echo "Survives SSH disconnects and reboots. To stop: loop stop"
        else
            die "LaunchAgent failed to start. Check: loop logs"
        fi
        return 0
    fi

    local daemon_script="$LIB_DIR/daemon.sh"
    if [ ! -f "$daemon_script" ]; then
        # Try relative to this script (running from source)
        daemon_script="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)/lib/daemon.sh"
    fi
    [ -f "$daemon_script" ] || die "daemon.sh not found. Is Simple Loop installed?"

    echo "Starting daemon (interval=${interval}s)..."
    echo "(Tip: run 'loop install-service' for SSH/reboot survival via launchd)"

    # Use caffeinate on macOS to prevent sleep
    if command -v caffeinate >/dev/null 2>&1; then
        caffeinate -s bash "$daemon_script" "$PROJECT_DIR" "$interval" \
            >> "$LOG_FILE" 2>&1 &
    else
        bash "$daemon_script" "$PROJECT_DIR" "$interval" \
            >> "$LOG_FILE" 2>&1 &
    fi
    local daemon_pid=$!

    sleep 1

    if kill -0 "$daemon_pid" 2>/dev/null; then
        echo "Daemon running (PID $daemon_pid). Logs: loop logs -f"
    else
        die "Daemon failed to start. Check: loop logs"
    fi
}

# ── stop ─────────────────────────────────────────────────────

cmd_stop() {
    require_loop_dir

    # LaunchAgent path — if the plist is installed, let launchctl unload stop the process
    local project_name
    project_name="$(basename "$PROJECT_DIR")"
    local _la_label="com.scaviefae.simpleloop.${project_name}"
    local _la_plist="$HOME/Library/LaunchAgents/${_la_label}.plist"

    if [ -f "$_la_plist" ]; then
        echo "Stopping via LaunchAgent (launchd-managed)..."
        launchctl unload "$_la_plist" 2>/dev/null && echo "LaunchAgent unloaded: $_la_label" || true
        rm -f "$PID_FILE"
        echo "Stopped. (LaunchAgent remains installed; daemon restarts on next login)"
        echo "To start again: loop start  |  To remove permanently: loop uninstall-service"
        return 0
    fi

    if ! [ -f "$PID_FILE" ]; then
        echo "No PID file found. Daemon not running."
        return 0
    fi

    local pid
    pid=$(cat "$PID_FILE")

    if ! kill -0 "$pid" 2>/dev/null; then
        echo "Stale PID file (process $pid not running). Cleaning up."
        rm -f "$PID_FILE"
        return 0
    fi

    echo "Stopping daemon (PID $pid)..."

    kill -- -"$pid" 2>/dev/null || kill "$pid" 2>/dev/null
    pkill -P "$pid" 2>/dev/null

    sleep 1

    if kill -0 "$pid" 2>/dev/null; then
        echo "Graceful stop failed, sending SIGKILL..."
        kill -9 "$pid" 2>/dev/null
        pkill -9 -P "$pid" 2>/dev/null
    fi

    rm -f "$PID_FILE"
    echo "Stopped."
}

# ── status ───────────────────────────────────────────────────

cmd_status() {
    require_loop_dir

    echo ""
    echo "╔══════════════════════════════════════╗"
    echo "║       Simple Loop Status             ║"
    echo "╚══════════════════════════════════════╝"
    echo ""

    # Queen error — brief-148: surface last queen error if recent and unresolved.
    # Suppressed when absent, or when >1h old and a success tick has happened since.
    if [ -f "$STATE_DIR/last-queen-error.json" ]; then
        python3 -c "
import json, sys, os, time
from datetime import datetime

error_file = '$STATE_DIR/last-queen-error.json'
success_file = '$STATE_DIR/last-queen-success.json'

try:
    with open(error_file) as f:
        err = json.load(f)
except Exception:
    print('  ⚠ Daemon error (file unreadable; see daemon.log)')
    print()
    sys.exit(0)

reason = err.get('reason', 'unknown error')
err_ts_str = err.get('ts', '')
log_tail = err.get('log_tail', '')

now = time.time()
err_epoch = now
try:
    err_dt = datetime.fromisoformat(err_ts_str.replace('Z', '+00:00'))
    err_epoch = err_dt.timestamp()
except Exception:
    pass

age_s = now - err_epoch

if age_s > 3600 and os.path.isfile(success_file):
    try:
        with open(success_file) as f:
            suc = json.load(f)
        suc_dt = datetime.fromisoformat(suc.get('ts', '').replace('Z', '+00:00'))
        if suc_dt.timestamp() > err_epoch:
            sys.exit(0)
    except Exception:
        pass

if age_s < 60:
    age_str = f'{int(age_s)}s ago'
elif age_s < 3600:
    age_str = f'{int(age_s) // 60}m ago'
else:
    age_str = f'{int(age_s) // 3600}h ago'

print(f'  ⚠ Daemon error ({age_str}): {reason}')
if log_tail:
    first_line = log_tail.strip().splitlines()[0] if log_tail.strip() else ''
    if first_line:
        print(f'    last log: {first_line}')
print('    fix: see TROUBLESHOOTING.md or daemon.log')
print()
" 2>/dev/null
    fi

    # Resolve actions.py once — used for heartbeat check and human_queue_summary.
    local actions_script="$LIB_DIR/actions.py"
    if [ ! -f "$actions_script" ]; then
        actions_script="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)/lib/actions.py"
    fi

    # Daemon — brief-014 fix 4: check heartbeat, not just PID.
    # process-alive ≠ loop-healthy. An 11h frozen daemon looks alive to ps
    # but silent to the log. Heartbeat staleness catches that.
    local hb_file="$STATE_DIR/heartbeat.json"
    if pid_alive; then
        local hb_stale="unknown"
        if [ -f "$actions_script" ]; then
            hb_stale=$(python3 -c "
import sys
sys.path.insert(0, '$(dirname "$actions_script")')
from actions import heartbeat_is_stale
print('STALE' if heartbeat_is_stale('$hb_file', interval_s=${HEARTBEAT_INTERVAL:-300}) else 'FRESH')
" 2>/dev/null || echo "unknown")
        fi
        if [ "$hb_stale" = "STALE" ]; then
            local hb_ts="unknown"
            [ -f "$hb_file" ] && hb_ts=$(python3 -c "import json; print(json.load(open('$hb_file')).get('ts','?'))" 2>/dev/null || echo "unknown")
            echo "  Daemon:   HUNG — PID $(cat "$PID_FILE") alive, heartbeat stale (last ts: $hb_ts)"
            echo "            process-alive ≠ loop-healthy. Recommend: loop stop && loop start"
        else
            echo "  Daemon:   RUNNING (PID $(cat "$PID_FILE"))"
        fi
    else
        echo "  Daemon:   STOPPED"
    fi

    # Project
    echo "  Project:  ${PROJECT_NAME:-$(basename "$PROJECT_DIR")}"
    echo "  Dir:      $PROJECT_DIR"

    # Pause state
    if [ -f "$SIGNALS_DIR/pause.json" ]; then
        local reason
        reason=$(python3 -c "import json; print(json.load(open('$SIGNALS_DIR/pause.json')).get('reason','unknown'))" 2>/dev/null || echo "unknown")
        echo "  Signal:   PAUSED ($reason)"
    else
        echo "  Signal:   clear"
    fi

    # Active briefs
    if [ -f "$STATE_DIR/running.json" ]; then
        python3 -c "
import json, sys, os
with open('$STATE_DIR/running.json') as f:
    rc = json.load(f)
active = rc.get('active', [])
pending = rc.get('completed_pending_eval', [])
worktrees_dir = '$LOOP_DIR/worktrees'
if active:
    for b in active:
        brief = b.get('brief', '?')
        wt = os.path.join(worktrees_dir, brief)
        wt_marker = ' [worktree]' if os.path.isdir(wt) else ''
        print(f\"  Active:   {brief} ({b.get('branch', '?')}){wt_marker}\")
elif pending:
    for b in pending:
        print(f\"  Pending:  {b.get('brief', '?')} (awaiting eval)\")
else:
    print('  Briefs:   none active')
" 2>/dev/null || echo "  Briefs:   no state"
    else
        echo "  Briefs:   no state file"
    fi

    # Awaiting you — brief-021: human-gated items from three sources.
    # Suppressed entirely when empty; no empty-state noise.
    if [ -f "$actions_script" ] && [ -f "$STATE_DIR/running.json" ]; then
        python3 -c "
import sys, os
sys.path.insert(0, '$(dirname "$actions_script")')
from actions import human_queue_summary
paths = {
    'running_file': '$STATE_DIR/running.json',
    'state_dir': '$STATE_DIR',
    'project_dir': '$PROJECT_DIR',
}
items = human_queue_summary(paths)
if items:
    print(f'  Awaiting you ({len(items)}):')
    for item in items:
        src = item['source'].ljust(16)
        bid = item['brief_id']
        summary = item['summary']
        kind = item.get('kind', '')
        kind_str = f'  [kind={kind}]' if kind else ''
        print(f'    {src}  {bid}{kind_str}   {summary}')
        disposition = item.get('queue_steward_disposition', '')
        if disposition:
            if kind == 'complete':
                disp_label = '★ ready for review (Mattie\'s gate)'
            else:
                disp_label = '⚠ needs daemon-side disposition'
            print(f'                       {disp_label}')
        hint = item.get('action_hint')
        if hint:
            print(f'                       → {hint}')
" 2>/dev/null
    fi

    # Re-queued (pending precondition) — brief-102: deterministic regex parse
    if [ -f "$actions_script" ] && [ -f "$STATE_DIR/goals.md" ]; then
        python3 -c "
import sys, os
sys.path.insert(0, '$(dirname "$actions_script")')
from actions import parse_requeued_briefs
items = parse_requeued_briefs('$STATE_DIR/goals.md', '$STATE_DIR/running.json')
if items:
    print(f'  Re-queued — pending precondition ({len(items)}):')
    for item in items:
        bid = item['brief_id']
        blocker = item['blocked_on']
        desc = item['description']
        if item['ready_to_dispatch']:
            status_tag = '  ★ ready to re-dispatch (precondition cleared)'
        else:
            status_tag = f'  blocked on {blocker}'
        print(f'    {bid}{status_tag}')
        print(f'      {desc}')
" 2>/dev/null
    fi

    echo ""

    # Recent logs
    if [ -f "$LOG_FILE" ]; then
        echo "  Recent log:"
        grep '^\[' "$LOG_FILE" 2>/dev/null | tail -5 | while IFS= read -r line; do
            echo "    $line"
        done
    fi
    echo ""
}

# ── logs ─────────────────────────────────────────────────────

cmd_logs() {
    require_loop_dir

    if [ "${1:-}" = "-f" ]; then
        if [ -f "$LOG_FILE" ]; then
            tail -f "$LOG_FILE"
        else
            die "No log file at $LOG_FILE"
        fi
    else
        if [ -f "$LOG_FILE" ]; then
            grep '^\[' "$LOG_FILE" 2>/dev/null | tail -30
        else
            echo "No logs yet."
        fi
    fi
}

# ── pause ────────────────────────────────────────────────────

cmd_pause() {
    require_loop_dir
    local reason="${1:-manual pause}"
    local timestamp
    timestamp=$(date -u +%Y-%m-%dT%H:%M:%SZ)

    mkdir -p "$SIGNALS_DIR"
    printf '{"reason":"%s","timestamp":"%s"}' "$reason" "$timestamp" > "$SIGNALS_DIR/pause.json"

    # Commit and push if in git
    if git -C "$PROJECT_DIR" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
        cd "$PROJECT_DIR"
        git add ".loop/state/signals/pause.json"
        git commit -m "loop: pause — $reason" -q 2>/dev/null
        git push "${GIT_REMOTE:-origin}" "${GIT_MAIN_BRANCH:-main}" -q 2>/dev/null || true
    fi

    echo "Paused: $reason"
}

# ── resume ───────────────────────────────────────────────────

cmd_resume() {
    require_loop_dir
    local instruction="${1:-}"
    local timestamp
    timestamp=$(date -u +%Y-%m-%dT%H:%M:%SZ)

    mkdir -p "$SIGNALS_DIR"

    if [ -n "$instruction" ]; then
        printf '{"instruction":"%s","timestamp":"%s"}' "$instruction" "$timestamp" > "$SIGNALS_DIR/resume.json"
    else
        printf '{"timestamp":"%s"}' "$timestamp" > "$SIGNALS_DIR/resume.json"
    fi

    # Commit and push if in git
    if git -C "$PROJECT_DIR" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
        cd "$PROJECT_DIR"
        git add ".loop/state/signals/resume.json"
        [ -f "$SIGNALS_DIR/pause.json" ] && git rm -q ".loop/state/signals/pause.json" 2>/dev/null || true
        git commit -m "loop: resume" -q 2>/dev/null
        git push "${GIT_REMOTE:-origin}" "${GIT_MAIN_BRANCH:-main}" -q 2>/dev/null || true
    fi

    echo "Resumed."
    [ -n "$instruction" ] && echo "Instruction: $instruction"
}

# ── metrics ──────────────────────────────────────────────────

cmd_metrics() {
    require_loop_dir

    local metrics_script="$LIB_DIR/metrics-report.py"
    if [ ! -f "$metrics_script" ]; then
        metrics_script="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)/lib/metrics-report.py"
    fi

    if [ -f "$metrics_script" ]; then
        python3 "$metrics_script" "$PROJECT_DIR" "$@"
    else
        # Inline fallback
        local metrics_file="$STATE_DIR/metrics.jsonl"
        if [ ! -f "$metrics_file" ] || [ ! -s "$metrics_file" ]; then
            echo "No metrics data yet."
            return 0
        fi
        python3 -c "
import json, sys
from collections import defaultdict

total = 0
by_source = defaultdict(lambda: {'cost': 0, 'count': 0})

with open('$metrics_file') as f:
    for line in f:
        line = line.strip()
        if not line: continue
        try:
            e = json.loads(line)
            cost = e.get('cost_usd', 0)
            total += cost
            src = e.get('source', 'unknown')
            by_source[src]['cost'] += cost
            by_source[src]['count'] += 1
        except: continue

print(f'Total cost: \${total:.2f}')
for src, data in sorted(by_source.items()):
    print(f'  {src}: \${data[\"cost\"]:.2f} ({data[\"count\"]} sessions)')
" "$@"
    fi
}

# ── add ──────────────────────────────────────────────────────

cmd_add() {
    require_loop_dir
    local module_name="${1:-}"
    [ -z "$module_name" ] && die "Usage: loop add <module>  (e.g., loop add research)"

    # Check if already installed
    if [ -d "$LOOP_DIR/modules/$module_name" ]; then
        die "Module '$module_name' is already installed. Use 'loop update' to refresh."
    fi

    # Find the module
    local module_src
    module_src=$(find_module_dir "$module_name") || die "Module '$module_name' not found.

Available modules:
  research   — Autonomous research: search, read, synthesize, evaluate
  build      — Autonomous build loop: brief → worker → evaluate → commit"

    echo ""
    echo "Installing module: $module_name"

    # Check for Agent Teams
    if command -v claude >/dev/null 2>&1; then
        local teams_enabled
        teams_enabled=$(claude config get enableAgentTeams 2>/dev/null || echo "")
        if [ "$teams_enabled" != "true" ]; then
            echo ""
            echo "  ⚠  Agent Teams is not enabled. Simple-loop modules use Agent Teams"
            echo "     to dispatch research agents and parallel workers."
            echo ""
            echo "     Enable it:  claude config set enableAgentTeams true"
            echo ""
            read -p "  Continue without Agent Teams? [y/N] " confirm
            if [ "${confirm:-n}" != "y" ] && [ "${confirm:-n}" != "Y" ]; then
                echo "  Aborted. Enable Agent Teams and try again."
                return 1
            fi
        fi
    fi

    # Create module directory
    mkdir -p "$LOOP_DIR/modules/$module_name"

    # Copy module config (from module.json defaults)
    if [ -f "$module_src/module.json" ]; then
        python3 -c "
import json, sys

with open('$module_src/module.json') as f:
    module = json.load(f)

# Extract config defaults from schema
config = {}
for key, spec in module.get('config_schema', {}).items():
    if 'default' in spec:
        config[key] = spec['default']

with open('$LOOP_DIR/modules/$module_name/config.json', 'w') as f:
    json.dump(config, f, indent=2)
    f.write('\n')
" || die "Failed to create module config."
    fi

    # Create state directory with empty state files
    if [ -d "$module_src/state" ] && [ -f "$module_src/state/schema.json" ]; then
        mkdir -p "$LOOP_DIR/modules/$module_name/state"
    fi

    # Copy/symlink skills to .claude/skills/
    if [ -d "$module_src/skills" ]; then
        mkdir -p "$PROJECT_DIR/.claude/skills"
        for skill_dir in "$module_src/skills"/*/; do
            [ -d "$skill_dir" ] || continue
            local skill_name
            skill_name=$(basename "$skill_dir")
            local target_dir="$PROJECT_DIR/.claude/skills/loop-${module_name}-${skill_name}"
            if [ -L "$target_dir" ]; then
                rm "$target_dir"
            fi
            ln -sf "$skill_dir" "$target_dir"
            echo "  Skill: /loop-${module_name}-${skill_name}"
        done
    fi

    # Install core skills if not already present
    local core_src
    core_src=$(find_core_dir 2>/dev/null) || true
    if [ -n "$core_src" ] && [ -d "$core_src/skills" ]; then
        mkdir -p "$PROJECT_DIR/.claude/skills"
        for skill_dir in "$core_src/skills"/*/; do
            [ -d "$skill_dir" ] || continue
            local skill_name
            skill_name=$(basename "$skill_dir")
            local target_dir="$PROJECT_DIR/.claude/skills/loop-${skill_name}"
            if [ ! -L "$target_dir" ] && [ ! -d "$target_dir" ]; then
                ln -sf "$skill_dir" "$target_dir"
                echo "  Skill: /loop-${skill_name} (core)"
            fi
        done
    fi

    # Inject claude-instructions into CLAUDE.md
    if [ -f "$module_src/claude-instructions.md" ]; then
        local claude_md="$PROJECT_DIR/CLAUDE.md"
        local marker="<!-- simple-loop:${module_name} -->"

        if [ -f "$claude_md" ] && grep -q "$marker" "$claude_md" 2>/dev/null; then
            echo "  CLAUDE.md: instructions already present, skipping"
        else
            echo "" >> "$claude_md"
            cat "$module_src/claude-instructions.md" >> "$claude_md"
            echo "  CLAUDE.md: appended ${module_name} instructions"
        fi
    fi

    # Create persistent docs if they don't exist
    for doc in SPEC.md HANDOFF.md RUNNING.md TROUBLESHOOTING.md; do
        if [ ! -f "$PROJECT_DIR/$doc" ]; then
            local template_doc
            if [ -n "$core_src" ] && [ -f "$core_src/templates/$doc" ]; then
                template_doc="$core_src/templates/$doc"
            fi
            if [ -n "${template_doc:-}" ] && [ -f "$template_doc" ]; then
                local project_name="${PROJECT_NAME:-$(basename "$PROJECT_DIR")}"
                sed "s/{{PROJECT_NAME}}/$project_name/g" "$template_doc" > "$PROJECT_DIR/$doc"
            fi
            echo "  Created: $doc"
        fi
    done

    # Update config.json modules list
    if [ -f "$LOOP_DIR/config.json" ]; then
        python3 -c "
import json
with open('$LOOP_DIR/config.json') as f:
    config = json.load(f)
modules = config.get('modules', [])
if '$module_name' not in modules:
    modules.append('$module_name')
config['modules'] = modules
with open('$LOOP_DIR/config.json', 'w') as f:
    json.dump(config, f, indent=2)
    f.write('\n')
"
    fi

    echo ""
    echo "  ✓ Module '$module_name' installed"
    echo ""
}

# ── remove ───────────────────────────────────────────────────

cmd_remove() {
    require_loop_dir
    local module_name="${1:-}"
    [ -z "$module_name" ] && die "Usage: loop remove <module>"

    if [ ! -d "$LOOP_DIR/modules/$module_name" ]; then
        die "Module '$module_name' is not installed."
    fi

    echo ""
    echo "Removing module: $module_name"

    # Remove symlinked skills
    if [ -d "$PROJECT_DIR/.claude/skills" ]; then
        for skill_link in "$PROJECT_DIR/.claude/skills"/loop-${module_name}-*; do
            if [ -L "$skill_link" ]; then
                rm "$skill_link"
                echo "  Removed skill: $(basename "$skill_link")"
            fi
        done
    fi

    # Remove claude-instructions block from CLAUDE.md
    local claude_md="$PROJECT_DIR/CLAUDE.md"
    if [ -f "$claude_md" ]; then
        local start_marker="<!-- simple-loop:${module_name} -->"
        local end_marker="<!-- /simple-loop:${module_name} -->"
        if grep -q "$start_marker" "$claude_md" 2>/dev/null; then
            python3 -c "
import re
with open('$claude_md') as f:
    content = f.read()
pattern = r'\n*<!-- simple-loop:${module_name} -->.*?<!-- /simple-loop:${module_name} -->\n*'
content = re.sub(pattern, '\n', content, flags=re.DOTALL)
with open('$claude_md', 'w') as f:
    f.write(content)
"
            echo "  CLAUDE.md: removed ${module_name} instructions"
        fi
    fi

    # Remove module directory (but not state — user may want to keep findings)
    read -p "  Remove module state (findings, sources, etc.)? [y/N] " remove_state
    if [ "${remove_state:-n}" = "y" ] || [ "${remove_state:-n}" = "Y" ]; then
        rm -rf "$LOOP_DIR/modules/$module_name"
        echo "  Removed: .loop/modules/$module_name/ (including state)"
    else
        rm -f "$LOOP_DIR/modules/$module_name/config.json"
        echo "  Removed config. State preserved at: .loop/modules/$module_name/state/"
    fi

    # Update config.json
    if [ -f "$LOOP_DIR/config.json" ]; then
        python3 -c "
import json
with open('$LOOP_DIR/config.json') as f:
    config = json.load(f)
modules = config.get('modules', [])
if '$module_name' in modules:
    modules.remove('$module_name')
config['modules'] = modules
with open('$LOOP_DIR/config.json', 'w') as f:
    json.dump(config, f, indent=2)
    f.write('\n')
"
    fi

    echo ""
    echo "  ✓ Module '$module_name' removed"
    echo ""
}

# ── update ───────────────────────────────────────────────────

cmd_update() {
    require_loop_dir

    echo ""
    echo "Updating simple-loop..."

    local core_src
    core_src=$(find_core_dir 2>/dev/null) || die "Core directory not found. Is simple-loop installed?"

    # Re-sync core skills
    if [ -d "$core_src/skills" ] && [ -d "$PROJECT_DIR/.claude/skills" ]; then
        for skill_dir in "$core_src/skills"/*/; do
            [ -d "$skill_dir" ] || continue
            local skill_name
            skill_name=$(basename "$skill_dir")
            local target_dir="$PROJECT_DIR/.claude/skills/loop-${skill_name}"
            if [ -L "$target_dir" ] || [ -d "$target_dir" ]; then
                rm -rf "$target_dir"
                ln -sf "$skill_dir" "$target_dir"
                echo "  Updated core skill: /loop-${skill_name}"
            fi
        done
    fi

    # Re-sync each installed module
    if [ -f "$LOOP_DIR/config.json" ]; then
        local modules
        modules=$(python3 -c "
import json
with open('$LOOP_DIR/config.json') as f:
    config = json.load(f)
for m in config.get('modules', []):
    print(m)
" 2>/dev/null)

        while IFS= read -r module_name; do
            [ -z "$module_name" ] && continue
            local module_src
            module_src=$(find_module_dir "$module_name" 2>/dev/null) || continue

            echo "  Updating module: $module_name"

            # Re-sync module skills
            if [ -d "$module_src/skills" ]; then
                for skill_dir in "$module_src/skills"/*/; do
                    [ -d "$skill_dir" ] || continue
                    local skill_name
                    skill_name=$(basename "$skill_dir")
                    local target_dir="$PROJECT_DIR/.claude/skills/loop-${module_name}-${skill_name}"
                    rm -rf "$target_dir"
                    ln -sf "$skill_dir" "$target_dir"
                done
            fi

            # Re-inject claude-instructions
            if [ -f "$module_src/claude-instructions.md" ]; then
                local claude_md="$PROJECT_DIR/CLAUDE.md"
                local start_marker="<!-- simple-loop:${module_name} -->"
                local end_marker="<!-- /simple-loop:${module_name} -->"

                if [ -f "$claude_md" ] && grep -q "$start_marker" "$claude_md" 2>/dev/null; then
                    # Replace existing block
                    python3 -c "
import re
with open('$claude_md') as f:
    content = f.read()
with open('$module_src/claude-instructions.md') as f:
    new_instructions = f.read()
pattern = r'<!-- simple-loop:${module_name} -->.*?<!-- /simple-loop:${module_name} -->'
content = re.sub(pattern, new_instructions.strip(), content, flags=re.DOTALL)
with open('$claude_md', 'w') as f:
    f.write(content)
"
                fi
            fi
        done <<< "$modules"
    fi

    # Re-seed simple_loop provenance in case install was updated
    if [ -f "$LOOP_DIR/config.json" ]; then
        _seed_simple_loop_config "$LOOP_DIR/config.json"
    fi

    echo ""
    echo "  ✓ Updated"
    echo ""
}

# ── modules ──────────────────────────────────────────────────

cmd_modules() {
    require_loop_dir

    echo ""
    echo "Installed modules:"

    if [ -f "$LOOP_DIR/config.json" ]; then
        python3 -c "
import json
with open('$LOOP_DIR/config.json') as f:
    config = json.load(f)
modules = config.get('modules', [])
if not modules:
    print('  (none)')
else:
    for m in modules:
        print(f'  - {m}')
" 2>/dev/null
    else
        echo "  (no config.json — v1 project?)"
    fi

    echo ""
    echo "Available modules:"
    echo "  research   — Autonomous research: search, read, synthesize, evaluate"
    echo "  build      — Autonomous build loop: brief → worker → evaluate → commit"
    echo ""
}

# ── approve ──────────────────────────────────────────────────

cmd_approve() {
    require_loop_dir
    local brief_id="${1:-}"
    [ -z "$brief_id" ] && die "Usage: loop approve <brief-id> [--waive N --reason '...' --tracking-brief brief-MMM]"
    shift

    local waive_count="" waive_reason="" tracking_brief=""
    while [ $# -gt 0 ]; do
        case "$1" in
            --waive)          waive_count="$2";    shift 2 ;;
            --reason)         waive_reason="$2";   shift 2 ;;
            --tracking-brief) tracking_brief="$2"; shift 2 ;;
            *) die "Unknown flag: $1" ;;
        esac
    done

    local actions_script="$LIB_DIR/actions.py"
    if [ ! -f "$actions_script" ]; then
        actions_script="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)/lib/actions.py"
    fi
    [ -f "$actions_script" ] || die "actions.py not found. Is Simple Loop installed?"

    python3 "$actions_script" approve-brief "$brief_id" "$PROJECT_DIR" \
        || die "approve-brief action failed"

    # Remove escalate.json if it belongs to this brief (guards path-mismatch mistakes)
    local escalate_path="$SIGNALS_DIR/escalate.json"
    if [ -f "$escalate_path" ]; then
        local esc_brief
        esc_brief=$(python3 -c "import json; print(json.load(open('$escalate_path')).get('brief',''))" 2>/dev/null || echo "")
        if [ "$esc_brief" = "$brief_id" ]; then
            rm -f "$escalate_path"
            echo "Removed escalate.json for $brief_id"
        fi
    fi

    local timestamp
    timestamp=$(date -u +%Y-%m-%dT%H:%M:%SZ)
    local event_json="{\"event\":\"auto_merge_approved_by_human\",\"brief\":\"$brief_id\",\"timestamp\":\"$timestamp\""
    if [ -n "$waive_count" ]; then
        event_json="$event_json,\"waive_count\":$waive_count"
        [ -n "$waive_reason" ]   && event_json="$event_json,\"waive_reason\":\"$waive_reason\""
        [ -n "$tracking_brief" ] && event_json="$event_json,\"tracking_brief\":\"$tracking_brief\""
    fi
    event_json="$event_json}"
    echo "$event_json" >> "$STATE_DIR/log.jsonl"

    if git -C "$PROJECT_DIR" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
        cd "$PROJECT_DIR"
        git add ".loop/state/running.json" ".loop/state/log.jsonl" 2>/dev/null
        git rm -q ".loop/state/signals/escalate.json" 2>/dev/null || true
        git commit -m "loop: approve $brief_id" -q 2>/dev/null || true
        git push "${GIT_REMOTE:-origin}" "${GIT_MAIN_BRANCH:-main}" -q 2>/dev/null || true
    fi

    echo "Approved: $brief_id"
    echo "Queued for merge — daemon will process on next tick."
    echo "(pending-merge.json written to: $STATE_DIR/pending-merge.json)"
}

# ── reject ───────────────────────────────────────────────────

cmd_reject() {
    require_loop_dir
    local brief_id="${1:-}"
    local reason="${2:-no reason given}"
    [ -z "$brief_id" ] && die "Usage: loop reject <brief-id> [reason]"

    local actions_script="$LIB_DIR/actions.py"
    if [ ! -f "$actions_script" ]; then
        actions_script="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)/lib/actions.py"
    fi
    [ -f "$actions_script" ] || die "actions.py not found. Is Simple Loop installed?"

    python3 "$actions_script" reject-brief "$brief_id" "$PROJECT_DIR" "$reason" \
        || die "reject-brief action failed"

    local escalate_path="$SIGNALS_DIR/escalate.json"
    if [ -f "$escalate_path" ]; then
        local esc_brief
        esc_brief=$(python3 -c "import json; print(json.load(open('$escalate_path')).get('brief',''))" 2>/dev/null || echo "")
        if [ "$esc_brief" = "$brief_id" ]; then
            rm -f "$escalate_path"
        fi
    fi

    # Remove worktree; leave branch for forensics
    local worktree_path="$LOOP_DIR/worktrees/$brief_id"
    if [ -d "$worktree_path" ]; then
        git -C "$PROJECT_DIR" worktree remove "$worktree_path" --force 2>/dev/null \
            || rm -rf "$worktree_path"
        echo "Removed worktree: $brief_id"
    fi

    local timestamp
    timestamp=$(date -u +%Y-%m-%dT%H:%M:%SZ)
    echo "{\"event\":\"brief_rejected_by_human\",\"brief\":\"$brief_id\",\"reason\":\"$reason\",\"timestamp\":\"$timestamp\"}" \
        >> "$STATE_DIR/log.jsonl"

    if git -C "$PROJECT_DIR" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
        cd "$PROJECT_DIR"
        git add ".loop/state/running.json" ".loop/state/log.jsonl" 2>/dev/null
        git rm -q ".loop/state/signals/escalate.json" 2>/dev/null || true
        git commit -m "loop: reject $brief_id — $reason" -q 2>/dev/null || true
        git push "${GIT_REMOTE:-origin}" "${GIT_MAIN_BRANCH:-main}" -q 2>/dev/null || true
    fi

    echo "Rejected: $brief_id"
    echo "Reason: $reason"
    echo "Branch preserved for forensics. Worktree removed."
}

# ── close ────────────────────────────────────────────────────

cmd_close() {
    require_loop_dir
    local brief_id="${1:-}"
    [ -z "$brief_id" ] && die "Usage: loop close <brief-id> --delivered-via <sha-or-pr-url> [reason]"
    shift

    local delivered_via=""
    local reason="delivered via external PR or merge"

    while [ $# -gt 0 ]; do
        case "$1" in
            --delivered-via)
                delivered_via="${2:-}"
                [ -z "$delivered_via" ] && die "--delivered-via requires a value"
                shift 2
                ;;
            --delivered-via=*)
                delivered_via="${1#--delivered-via=}"
                shift
                ;;
            *)
                reason="$*"
                break
                ;;
        esac
    done

    [ -z "$delivered_via" ] && die "Usage: loop close <brief-id> --delivered-via <sha-or-pr-url> [reason]"

    local actions_script="$LIB_DIR/actions.py"
    if [ ! -f "$actions_script" ]; then
        actions_script="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)/lib/actions.py"
    fi
    [ -f "$actions_script" ] || die "actions.py not found. Is Simple Loop installed?"

    python3 "$actions_script" close-brief "$brief_id" "$PROJECT_DIR" "$delivered_via" "$reason" \
        || die "close-brief action failed"

    # Commit the projected state files.
    if git -C "$PROJECT_DIR" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
        cd "$PROJECT_DIR"
        git add ".loop/state/running.json" ".loop/state/runtime-events.jsonl" \
                ".loop/state/log.jsonl" 2>/dev/null
        git commit -m "loop: close $brief_id as superseded — $delivered_via" -q 2>/dev/null || true
        git push "${GIT_REMOTE:-origin}" "${GIT_MAIN_BRANCH:-main}" -q 2>/dev/null || true
    fi

    echo "Closed: $brief_id"
    echo "Delivered via: $delivered_via"
    echo "Branch preserved for forensics. Worktree removed."
}

