}

# ── install-service / uninstall-service ──────────────────────

cmd_install_service() {
    require_loop_dir

    # Parse args: positional interval + optional --lane <name>.
    # A lane scopes this daemon to one Program: (brief-152). Empty/whitespace
    # lane = no lane = stock single-daemon install (plist diffs clean).
    local interval="" lane=""
    while [ "$#" -gt 0 ]; do
        case "$1" in
            --lane)   shift; lane="${1:-}" ;;
            --lane=*) lane="${1#--lane=}" ;;
            *)        [ -z "$interval" ] && interval="$1" ;;
        esac
        shift
    done
    interval="${interval:-${HEARTBEAT_INTERVAL:-300}}"
    # Trim surrounding whitespace; a blank lane stays no-filter.
    lane="$(printf '%s' "$lane" | sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//')"

    # Resolve installed lib dir — same logic as cmd_start
    local daemon_script="$LIB_DIR/daemon.sh"
    if [ ! -f "$daemon_script" ]; then
        daemon_script="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)/lib/daemon.sh"
    fi
    [ -f "$daemon_script" ] || die "daemon.sh not found. Is Simple Loop installed?"
    local resolved_lib_dir
    resolved_lib_dir="$(dirname "$daemon_script")"

    # Resolve plist template
    local plist_template="$TEMPLATES_DIR/com.scaviefae.simpleloop.plist"
    if [ ! -f "$plist_template" ]; then
        plist_template="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)/templates/com.scaviefae.simpleloop.plist"
    fi
    [ -f "$plist_template" ] || die "Plist template not found. Is Simple Loop installed? (looked at: $plist_template)"

    local project_name
    project_name="$(basename "$PROJECT_DIR")"
    local label="com.scaviefae.simpleloop.${project_name}"
    local agents_dir="$HOME/Library/LaunchAgents"
    local plist_dest="${agents_dir}/${label}.plist"
    local log_file="$LOG_DIR/daemon.log"

    mkdir -p "$agents_dir"
    mkdir -p "$LOG_DIR"

    # Read git.main_branch from config.json; fallback to "main" with a warning
    local main_branch _config_json="$LOOP_DIR/config.json"
    if [ -f "$_config_json" ]; then
        main_branch="$(python3 - "$_config_json" <<'PYEOF' 2>/dev/null
import json, sys
try:
    with open(sys.argv[1]) as f:
        c = json.load(f)
    val = c.get('git', {}).get('main_branch', '')
    print(val if val else 'main')
except Exception:
    print('__MALFORMED__')
PYEOF
        )"
        if [ "$main_branch" = "__MALFORMED__" ] || [ -z "$main_branch" ]; then
            echo "warning: .loop/config.json missing or malformed — defaulting GIT_MAIN_BRANCH=main"
            main_branch="main"
        fi
    else
        echo "warning: .loop/config.json not found — defaulting GIT_MAIN_BRANCH=main"
        main_branch="main"
    fi

    # Interpolate template — sed-safe: escape / in paths
    local safe_project_dir safe_lib_dir safe_log_file safe_home safe_path safe_main_branch
    safe_project_dir="$(printf '%s\n' "$PROJECT_DIR" | sed 's/[\/&]/\\&/g')"
    safe_lib_dir="$(printf '%s\n' "$resolved_lib_dir" | sed 's/[\/&]/\\&/g')"
    safe_log_file="$(printf '%s\n' "$log_file" | sed 's/[\/&]/\\&/g')"
    safe_home="$(printf '%s\n' "$HOME" | sed 's/[\/&]/\\&/g')"
    safe_path="$(printf '%s\n' "$PATH" | sed 's/[\/&]/\\&/g')"
    safe_main_branch="$(printf '%s\n' "$main_branch" | sed 's/[\/&]/\\&/g')"

    # LOOP_LANE plist injection. Each placeholder sits alone on its line, so the
    # no-lane case is a clean line-delete (stock plist byte-for-byte unchanged)
    # and the with-lane case is a single-line substitution (no multi-line sed).
    local lane_key_sed lane_val_sed
    if [ -n "$lane" ]; then
        local safe_lane
        safe_lane="$(printf '%s' "$lane" | sed 's/[|&]/\\&/g')"
        lane_key_sed="s|{{LOOP_LANE_KEY}}|        <key>LOOP_LANE</key>|"
        lane_val_sed="s|{{LOOP_LANE_VAL}}|        <string>${safe_lane}</string>|"
    else
        lane_key_sed="/{{LOOP_LANE_KEY}}/d"
        lane_val_sed="/{{LOOP_LANE_VAL}}/d"
    fi

    sed \
        -e "s/{{PROJECT_NAME}}/${project_name}/g" \
        -e "s/{{PROJECT_DIR}}/${safe_project_dir}/g" \
        -e "s/{{LIB_DIR}}/${safe_lib_dir}/g" \
        -e "s/{{INTERVAL}}/${interval}/g" \
        -e "s/{{LOG_FILE}}/${safe_log_file}/g" \
        -e "s/{{HOME}}/${safe_home}/g" \
        -e "s/{{PATH}}/${safe_path}/g" \
        -e "s/{{GIT_MAIN_BRANCH}}/${safe_main_branch}/g" \
        -e "$lane_key_sed" \
        -e "$lane_val_sed" \
        "$plist_template" > "$plist_dest"

    echo "LaunchAgent written: $plist_dest"
    [ -n "$lane" ] && echo "Lane: $lane (LOOP_LANE in plist EnvironmentVariables)"

    # Unload first if already loaded (idempotent re-install)
    launchctl unload "$plist_dest" 2>/dev/null || true

    launchctl load -w "$plist_dest"
    echo "LaunchAgent loaded: $label"
    echo ""
    echo "Daemon is now managed by launchd. It will:"
    echo "  - Start automatically on login"
    echo "  - Restart automatically if it crashes"
    echo "  - Survive SSH disconnects and terminal closes"
    echo ""
    echo "Verify: launchctl list | grep simpleloop"
    echo "Logs:   loop logs -f"
}

cmd_uninstall_service() {
    require_loop_dir

    local project_name
    project_name="$(basename "$PROJECT_DIR")"
    local label="com.scaviefae.simpleloop.${project_name}"
    local plist_dest="$HOME/Library/LaunchAgents/${label}.plist"

    if [ ! -f "$plist_dest" ]; then
        echo "No LaunchAgent plist found at $plist_dest"
        echo "Nothing to uninstall."
        return 0
    fi

    launchctl unload "$plist_dest" 2>/dev/null && echo "LaunchAgent unloaded: $label" || true
    rm -f "$plist_dest"
    echo "Removed: $plist_dest"
    echo ""
    echo "LaunchAgent uninstalled. Use 'loop start' to run the daemon manually."
}

# ── cleanup ──────────────────────────────────────────────────

cmd_cleanup() {
    require_loop_dir

    echo ""
    echo "Cleaning up worktrees..."

    local actions_script="$LIB_DIR/actions.py"
    if [ ! -f "$actions_script" ]; then
        actions_script="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)/lib/actions.py"
    fi

    if [ -f "$actions_script" ]; then
        python3 "$actions_script" cleanup "$PROJECT_DIR"
    else
        die "actions.py not found. Is Simple Loop installed?"
    fi

    echo ""
}

# ── info ─────────────────────────────────────────────────────

cmd_info() {
    local install_dir="$SIMPLE_LOOP_HOME"
    local provenance_file="$install_dir/PROVENANCE.json"
    local binary_path
    binary_path=$(command -v loop 2>/dev/null || echo "$HOME/.local/bin/loop")
    local claude_dir="$HOME/.claude"

    echo ""
    echo "simple-loop:"

    python3 - "$provenance_file" "$install_dir" "$binary_path" "$claude_dir" <<'PYEOF'
import json, sys, os

provenance_file, install_dir, binary_path, claude_dir = sys.argv[1:]

source_repo = "unknown"
source_commit = "unknown"
source_dirty = "unknown"
version = "unknown"

if os.path.exists(provenance_file):
    try:
        with open(provenance_file) as f:
            p = json.load(f)
        source_repo = p.get("source_repo", "unknown")
        source_commit = p.get("source_commit", "unknown")
        source_dirty = "dirty" if p.get("source_dirty") else "clean"
        version = p.get("version", "unknown")
    except Exception:
        pass

print(f"  source:    {source_repo}  (commit {source_commit}, {source_dirty})")
print(f"  install:   {install_dir}  (version {version}, commit {source_commit})")
print(f"  binary:    {binary_path}")

agents_dir = os.path.join(claude_dir, "agents")
skills_dir = os.path.join(claude_dir, "skills")
agent_count = 0
skill_count = 0
if os.path.isdir(agents_dir):
    agent_count = len([f for f in os.listdir(agents_dir) if f.startswith("loop-") and f.endswith(".md")])
if os.path.isdir(skills_dir):
    skill_count = len([d for d in os.listdir(skills_dir) if d.startswith("loop-") and os.path.isdir(os.path.join(skills_dir, d))])
print(f"  agents:    {agents_dir}/loop-*.md  ({agent_count})")
print(f"  skills:    {skills_dir}/loop-*/    ({skill_count})")
PYEOF

    # Project section — only when inside a loop project
    local loop_dir
    if loop_dir=$(find_loop_dir 2>/dev/null); then
        local project_dir
        project_dir="$(dirname "$loop_dir")"
        local config_file="$loop_dir/config.json"

        # Drift check — captures first failing queued brief or "none"
        local drift_line=""
        if [ -f "$LIB_DIR/lint.py" ]; then
            drift_line=$(cd "$project_dir" && python3 "$LIB_DIR/lint.py" --summary 2>/dev/null) || true
        fi
        [ -z "$drift_line" ] && drift_line="none"

        echo ""
        python3 - "$loop_dir" "$config_file" "$project_dir" "$drift_line" <<'PYEOF'
import json, sys, os

loop_dir, config_file, project_dir, drift_line = sys.argv[1:]
config = {}
if os.path.exists(config_file):
    try:
        with open(config_file) as f:
            config = json.load(f)
    except Exception:
        pass

project_name = config.get("project_name", os.path.basename(project_dir))
version = config.get("version", "unknown")
sl = config.get("simple_loop", {})
last_commit = sl.get("commit", "unknown")

print(f"project ({project_name}):")
print(f"  .loop root:  {loop_dir}")
print(f"  config:      version {version}, last-installed {last_commit}")

# Brief counts from wiki/briefs/cards/*/index.md YAML frontmatter
cards_dir = os.path.join(project_dir, "wiki", "briefs", "cards")
status_counts = {}
total_briefs = 0
if os.path.isdir(cards_dir):
    for card_id in sorted(os.listdir(cards_dir)):
        if card_id.startswith("."):
            continue
        card_path = os.path.join(cards_dir, card_id, "index.md")
        if not os.path.isfile(card_path):
            continue
        status = ""
        try:
            with open(card_path) as fh:
                in_fm = False
                for line in fh:
                    stripped = line.strip()
                    if stripped == "---":
                        if not in_fm:
                            in_fm = True
                            continue
                        else:
                            break
                    if in_fm and stripped.lower().startswith("status:"):
                        status = stripped.split(":", 1)[1].strip().lower()
                        break
        except Exception:
            pass
        if status:
            total_briefs += 1
            status_counts[status] = status_counts.get(status, 0) + 1

ORDERED = ["active", "awaiting_review", "queued", "draft"]
parts = []
for s in ORDERED:
    n = status_counts.get(s, 0)
    if n > 0:
        parts.append(f"{n} {s}")
for s, n in sorted(status_counts.items()):
    if s not in ORDERED and n > 0:
        parts.append(f"{n} {s}")

if parts:
    print(f"  briefs:      {total_briefs} ({', '.join(parts)})")
else:
    print(f"  briefs:      {total_briefs}")

print(f"  drift:       {drift_line}")
PYEOF
    fi

    echo ""
}

# ── help ─────────────────────────────────────────────────────

cmd_help() {
    cat <<'EOF'
Usage: loop <command> [args]

Project setup:
  init                     Set up .loop/ in current directory (interactive)
  add <module>             Install a module (research, build)
  remove <module>          Remove a module
  update                   Update core + module skills and instructions
  modules                  List installed and available modules

Work:
  brief "title"            Write a brief with the spec agent (interactive)
  brief --no-interactive   Create brief from template, open in $EDITOR
  start [interval]         Start the daemon (default: 300s heartbeat)
  stop                     Stop the daemon
  install-service [interval]  Install as macOS LaunchAgent (survives SSH/reboot)
  uninstall-service           Remove the LaunchAgent

Monitor:
  status                   Show daemon state, active brief, recent logs
  info                     Show framework provenance and project state at a glance
  logs [-f]                Show/follow daemon logs
  metrics [--since DATE]   Cost report from metrics

Signals:
  pause [reason]           Pause daemon (commits + pushes signal)
  resume [instruction]     Resume daemon (commits + pushes signal)
  approve <brief-id>       Approve a brief awaiting human review (queue for merge)
                           --waive N --reason '...' --tracking-brief brief-MMM
                           for partial-approval with waiver record
  reject <brief-id> [why]  Reject a brief: mark in history, remove worktree
  close <brief-id> --delivered-via <sha-or-url> [why]
                           Close a brief as delivered-elsewhere: supersede from
                           any queue state, append delivered_via to history,
                           remove worktree (branch preserved). Idempotent.

Quality:
  lint <path>              Lint a brief file or directory for format drift
                           <path> = single file or wiki/briefs/cards/ dir
  sweep [--quick]          Deterministic state validator — 4 structural predicates
  sweep [--auto-route]     Also move orphaned active[] entries to awaiting_review

Maintenance:
  cleanup                  Remove worktrees for completed/merged briefs

  help                     Show this message

Quickstart:
  loop init                # Answer a few questions
  loop add research        # Install the research module
  loop brief "your topic"  # Write a brief
  loop start               # Start the autonomous loop
  loop status              # Check progress
EOF
}

# ── Dispatch ─────────────────────────────────────────────────

case "${1:-help}" in
    init)    shift; cmd_init "$@" ;;
    add)     shift; cmd_add "$@" ;;
    remove)  shift; cmd_remove "$@" ;;
    update)  cmd_update ;;
    modules) cmd_modules ;;
    brief)   shift; cmd_brief "$@" ;;
    start)   shift; cmd_start "$@" ;;
    stop)    cmd_stop ;;
    status)  cmd_status ;;
    info)    cmd_info ;;
    logs)    shift; cmd_logs "$@" ;;
    pause)   shift; cmd_pause "$@" ;;
    resume)  shift; cmd_resume "$@" ;;
    approve) shift; cmd_approve "$@" ;;
    reject)  shift; cmd_reject "$@" ;;
    close)   shift; cmd_close "$@" ;;
    metrics) shift; cmd_metrics "$@" ;;
    lint)    shift; cmd_lint "$@" ;;
    sweep)   shift; cmd_sweep "$@" ;;
    install-service)   shift; cmd_install_service "$@" ;;
    uninstall-service) cmd_uninstall_service ;;
    cleanup) cmd_cleanup ;;
    help|--help|-h) cmd_help ;;
    *)       echo "Unknown command: $1"; cmd_help; exit 1 ;;
esac
